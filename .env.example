# =============================================================================
# Studio thumbnails (recommended for reloadable images)
# =============================================================================
# 1) Create a writable folder (any disk). Use an ABSOLUTE path.
#    macOS example:  mkdir -p "$HOME/upgrade-life-assets"
# 2) Copy this file to `.env.local` and fill values. Restart `npm run dev` after changes.
# 3) Apply Supabase migrations in `supabase/migrations/` (includes `thumbnail_generation_events`).
# 4) Generate a thumbnail on Channel desk → Upcoming; files appear under
#    `{UPGRADE_LIFE_LOCAL_ASSETS_ROOT}/thumbnails/{year}/{month}/`. The app stores
#    `local_relative_path` + optional `idea_id` in Supabase and serves images via
#    `/api/studio/thumbnails/by-id/{id}` or `.../file?rel=...`.

# Absolute path to the assets root (alias: LOCAL_ASSETS_ROOT)
UPGRADE_LIFE_LOCAL_ASSETS_ROOT=
# LOCAL_ASSETS_ROOT=

# =============================================================================
# Motion clips (ffmpeg Ken Burns previews, Studio → Visuals)
# =============================================================================
# Install ffmpeg (includes ffprobe). macOS: brew install ffmpeg
# If not on PATH when Next.js runs, set absolute paths:
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role JWT (server-only). Required for `thumbnail_generation_events` inserts.
# Never expose this key to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# =============================================================================
# Gemini (ideas, thumbnails, scripts)
# =============================================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Optional: pin one Imagen 4 model for thumbnails (default tries generate → fast → ultra).
# Examples: imagen-4.0-generate-001 | imagen-4.0-fast-generate-001 | imagen-4.0-ultra-generate-001
# GEMINI_IMAGE_MODEL=

# Optional: Gemini TTS (Studio → Audio). Default tries, in order:
# gemini-2.5-flash-tts → gemini-2.5-flash-lite-preview-tts → gemini-3.1-flash-tts-preview
# GEMINI_TTS_MODEL=gemini-2.5-flash-tts
# Prebuilt voice name (e.g. Charon, Kore, Puck) — see Gemini / Chirp 3 HD voice lists.
# GEMINI_TTS_VOICE=Charon
# If TTS returns raw PCM (`audio/l16`) and pitch/speed is wrong, set sample rate (Hz). Default 24000.
# GEMINI_TTS_PCM_SAMPLE_RATE=24000
# If audio sounds like it speeds up / gets dull toward the end, try MP3 from the API (skips PCM→WAV):
# (omit or set to `off` / `pcm` to always use raw LINEAR16)
# GEMINI_TTS_RESPONSE_MIME=audio/mp3
#
# If voice sounds comb-filtered or “phasey”, try stereo PCM (some stacks return 2ch interleaved):
# GEMINI_TTS_PCM_CHANNELS=2

# Optional: Supabase CLI / MCP — not used by Next.js createClient()
# SUPABASE_ACCESS_TOKEN=
